{
  "name": "doc-rag-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify API for Document Q&A with citations",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
